rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /leaderboards/{unitId}/scores/{scoreId} {
      allow read: if true;

      // NOTE(난이도 3단 모드, 2026-07-13): difficulty 필드 검증 추가. 이 파일을 수정한 뒤
      // Firebase 콘솔(Firestore Database > 규칙)에 반드시 재게시해야 실제로 적용된다.
      // NOTE(10분 챌린지 모드, 2026-07-15): mode 필드 검증 추가. 이 파일을 수정한 뒤
      // Firebase 콘솔(Firestore Database > 규칙)에 반드시 재게시해야 실제로 적용된다.
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
          'nickname', 'unitId', 'grade', 'semester', 'score',
          'survivalTime', 'level', 'kills', 'weightedScore',
          'difficulty', 'mode', 'authUid', 'createdAt'
        ])
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() > 0
        && request.resource.data.nickname.size() <= 12
        && request.resource.data.unitId is string
        && request.resource.data.unitId == unitId
        && request.resource.data.grade is number
        && request.resource.data.grade >= 5
        && request.resource.data.grade <= 6
        && request.resource.data.semester is number
        && request.resource.data.semester >= 1
        && request.resource.data.semester <= 2
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 1000000
        && request.resource.data.survivalTime is number
        && request.resource.data.survivalTime >= 0
        && request.resource.data.survivalTime <= 7200
        && request.resource.data.level is number
        && request.resource.data.level >= 1
        && request.resource.data.level <= 999
        && request.resource.data.kills is number
        && request.resource.data.kills >= 0
        && request.resource.data.kills <= 1000000
        && request.resource.data.weightedScore is number
        && request.resource.data.weightedScore >= 0
        && request.resource.data.weightedScore <= 1000000
        && (!('difficulty' in request.resource.data)
          || request.resource.data.difficulty in ['easy', 'normal', 'hard'])
        && (!('mode' in request.resource.data)
          || request.resource.data.mode in ['adventure', 'timeAttack'])
        && request.resource.data.authUid == request.auth.uid
        && request.resource.data.createdAt == request.time;

      allow update, delete: if false;
    }
  }
}
